# ──────────────────────────────────────────────────────────────────────────────
# AI Mental Health Assistant — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME="AI Mental Health Assistant"
APP_VERSION="1.0.0"
DEBUG=True

# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/mental_health_db
DATABASE_ECHO=False

# JWT Security
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_use_a_long_random_string_minimum_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
