# ──────────────────────────────────────────────────────────────────────────────
# .gitignore for AI Mental Health Assistant (Python/FastAPI)
# ──────────────────────────────────────────────────────────────────────────────

# Environment & secrets
.env
*.env
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
sdist/
var/
wheels/
*.pyc

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Alembic
alembic/versions/*.pyc

# Logs
*.log
logs/
